<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg_gradient"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#E61C1E21"
        app:layout_constraintTop_toTopOf="parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="20sp" />
            <ImageButton
                android:id="@+id/btnLanguage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_mapmode"
                android:contentDescription="@string/desc_btn_language"
                app:tint="@color/white" />
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <FrameLayout
        android:id="@+id/cardProfileContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:clipChildren="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/my_toolbar">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            app:cardBackgroundColor="#25282B"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp">
                <androidx.cardview.widget.CardView
                    android:id="@+id/imgProfileContainer"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardCornerRadius="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:id="@+id/imgProfileHeader"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/shape_square"
                        android:contentDescription="@string/desc_profile_image" />
                </androidx.cardview.widget.CardView>
                <TextView
                    android:id="@+id/txtProfileName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/label_pseudo_default"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/imgProfileContainer"
                    app:layout_constraintTop_toTopOf="@id/imgProfileContainer" />
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    app:layout_constraintBottom_toBottomOf="@id/imgProfileContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/imgProfileContainer">
                    <ProgressBar
                        android:id="@+id/progressSuccess"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:max="100"
                        android:progressDrawable="@drawable/custom_progress_bar" />
                    <TextView
                        android:id="@+id/txtProgressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/default_percent"
                        android:textColor="@color/white"
                        android:textSize="10sp" />
                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:id="@+id/overlay_profile"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#B3121212"
            android:elevation="5dp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/lock_card_profile"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-8dp"
            android:layout_marginEnd="-8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_lock"
                android:contentDescription="@string/desc_icon_lock"
                app:tint="#212121" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_creation_tools"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        android:clipChildren="false"
        app:layout_constraintBottom_toTopOf="@+id/battle_full_container"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:clipChildren="false">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnPasteGemini"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:backgroundTint="#25282B"
                app:fabSize="mini"
                android:contentDescription="@string/desc_btn_gemini"
                app:srcCompat="@android:drawable/ic_menu_edit"
                app:tint="#FFB74D" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/overlay_gemini"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"
                app:cardBackgroundColor="#E6212121"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lock_card_gemini"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="-4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="6dp"
                app:cardElevation="6dp"
                android:visibility="gone">
                <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="center" android:src="@android:drawable/ic_lock_lock" android:contentDescription="@string/desc_icon_lock" app:tint="#212121" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:clipChildren="false">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnAddPdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:backgroundTint="#25282B"
                app:fabSize="mini"
                android:contentDescription="@string/desc_btn_pdf"
                app:srcCompat="@android:drawable/ic_menu_save"
                app:tint="@color/white" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/overlay_pdf"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"
                app:cardBackgroundColor="#E6212121"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lock_card_pdf"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="-4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="6dp"
                app:cardElevation="6dp"
                android:visibility="gone">
                <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="center" android:src="@android:drawable/ic_lock_lock" android:contentDescription="@string/desc_icon_lock" app:tint="#212121" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:clipChildren="false">
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnCreateQuiz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:backgroundTint="#1976D2"
                app:fabSize="mini"
                android:contentDescription="@string/desc_btn_create_quiz"
                app:srcCompat="@android:drawable/ic_input_add"
                app:tint="@color/white" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/overlay_create"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone"
                app:cardBackgroundColor="#E6212121"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lock_card_create"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="-4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="6dp"
                app:cardElevation="6dp"
                android:visibility="gone">
                <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_gravity="center" android:src="@android:drawable/ic_lock_lock" android:contentDescription="@string/desc_icon_lock" app:tint="#212121" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/avatar_container"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="40dp"
        android:clipChildren="false"
        app:layout_constraintBottom_toTopOf="@id/battle_full_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/shape_square"
            android:contentDescription="@string/desc_avatar_image" />

        <ImageButton
            android:id="@+id/btnDressing"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/circle_accent"
            android:src="@android:drawable/ic_menu_set_as"
            android:contentDescription="@string/desc_btn_dressing"
            app:tint="@color/white" />

        <View
            android:id="@+id/overlay_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3121212"
            android:elevation="5dp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/lock_card_avatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="8dp"
            app:cardElevation="8dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_lock"
                android:contentDescription="@string/desc_icon_lock"
                app:tint="#212121" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/battle_full_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/battle_inner_layout"
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_battle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.60" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="-45dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/guideline_battle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageButton
                    android:id="@+id/btnPlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:scaleType="fitXY"
                    android:src="@drawable/brush_jouer"
                    android:contentDescription="@string/btn_learn" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginEnd="25dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/btn_learn"
                    android:textColor="@color/white"
                    android:textSize="20sp" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginStart="-45dp"
                android:layout_marginEnd="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/guideline_battle"
                app:layout_constraintTop_toTopOf="parent">
                <ImageButton
                    android:id="@+id/btnDuel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:scaleType="fitXY"
                    android:src="@drawable/brush_duel"
                    android:contentDescription="@string/btn_duel" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="25dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/btn_duel"
                    android:textColor="@color/white"
                    android:textSize="20sp" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/overlay_battle"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="#B3121212"
            android:elevation="5dp"
            android:visibility="gone" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/lock_card_battle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="10dp"
            app:cardElevation="10dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_lock"
                android:contentDescription="@string/desc_icon_lock"
                app:tint="#212121" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStory"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="20dp"
        android:text="@string/btn_story"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="#FF9800"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>