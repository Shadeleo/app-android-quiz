<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ProjetMobileL3InformatiqueLeoPEREIRA" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>

        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">#212121</item>

        <item name="android:windowBackground">@color/bg_light</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.ProjetMobileL3InformatiqueLeoPEREIRA" parent="Base.Theme.ProjetMobileL3InformatiqueLeoPEREIRA" />

    <style name="AnswerBoxStyle">
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/box</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/gray_text</item>
        <item name="colorAccent">@color/accent_pro</item>
        <item name="colorPrimary">@color/accent_pro</item>
    </style>
</resources>